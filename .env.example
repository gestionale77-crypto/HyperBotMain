HYPERBOT_APP_NAME=hyperbot
HYPERBOT_APP_VERSION=0.1.0
HYPERBOT_ENVIRONMENT=development
HYPERBOT_EXCHANGE_NAME=hyperliquid
HYPERBOT_ENABLE_WEBSOCKET=true
HYPERBOT_REST_BASE_URL=https://api.hyperliquid-testnet.xyz
HYPERBOT_WEBSOCKET_BASE_URL=wss://api.hyperliquid-testnet.xyz/ws
HYPERBOT_LOG_LEVEL=INFO
HYPERBOT_SQLITE_PATH=./data/hyperbot.db
HYPERBOT_API_TESTNET=true
HYPERBOT_ACCOUNT_ADDRESS=0xYOUR_MAIN_WALLET_ADDRESS
HYPERBOT_API_PRIVATE_KEY=0xYOUR_AGENT_PRIVATE_KEY
